# Copier vers .env.local sur chaque machine (local + VPS). Ne pas commiter .env.local.

# PostgreSQL — ex. Docker Compose du projet (port 5433 sur la machine hôte) :
# DATABASE_URL=postgresql://moonkey:moonkey@127.0.0.1:5433/moonkey
#
# Si l’app Next tourne dans le même réseau Docker que le service `db` :
# DATABASE_URL=postgresql://moonkey:moonkey@db:5432/moonkey

DATABASE_URL=
